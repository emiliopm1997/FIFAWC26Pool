{
  "name": "FIFA WC 2026 Pool Dev Container",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "settings": {
    "python.defaultInterpreterPath": "/opt/conda/envs/wc_pool_env/bin/python",
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true,
    "editor.rulers": [80],
    "editor.wordWrapColumn": 80,

    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 1000,

    "editor.codeActionsOnSave": {
      "source.organizeImports": true
    },

    "python.linting.enabled": true,
    "python.linting.flake8Enabled": true,
    "python.linting.pylintEnabled": false,

    "python.analysis.typeCheckingMode": "basic",

    "autoDocstring.docstringFormat": "numpy",

    "notebook.formatOnSave.enabled": true
  },
  "extensions": [
    "ms-python.python",
    "ms-python.vscode-pylance",
    "ms-toolsai.jupyter",
    "njpwerner.autodocstring",
    "ms-azuretools.vscode-docker",
    "eamodio.gitlens",
    "ms-vscode.makefile-tools",
    "yzhang.markdown-all-in-one",
    "streetsidesoftware.code-spell-checker",
    "ms-python.black-formatter",
    "ms-python.flake8",
    "aaron-bond.better-comments",
    "humao.rest-client",
    "ms-ossdata.vscode-database",
    "alexcvzz.vscode-sqlite",
    "keyshout.sqlite-db-viewer",
    "cweijan.vscode-database-client2",
    "tal7aouy.icons"
  ],
  "postCreateCommand": "conda env create -f environment.yml || conda env update -f environment.yml",
  "remoteUser": "root"
}